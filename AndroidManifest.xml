<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permission lokasi -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/logogo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logogo"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyLibrary">

        <!-- Splash pertama -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Welcome -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="false"/>

        <!-- Main -->
        <activity
            android:name=".MainActivity"
            android:exported="false"/>

        <activity
            android:name=".FavoritActivity"
            android:exported="false"/>

        <activity
            android:name=".KoleksiActivity"
            android:exported="false"/>

        <!-- Tambah Buku -->
        <activity
            android:name=".AddBookActivity"
            android:exported="false"/>

        <!-- Detail Buku -->
        <activity
            android:name=".DetailBookActivity"
            android:exported="false"/>

        <!-- Chat AI -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"/>

        <!-- Statistik -->
        <activity
            android:name=".StatistikActivity"
            android:exported="false"/>

    </application>

</manifest>