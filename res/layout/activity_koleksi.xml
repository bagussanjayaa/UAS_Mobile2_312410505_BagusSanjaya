<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_mylibrary">

    <!-- ================= HEADER ================= -->

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="95dp"
        android:background="#1976D2"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Collection"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Semua buku yang kamu simpan"
                android:textColor="#DDEBFF"
                android:textSize="14sp"/>
        </LinearLayout>

    </RelativeLayout>

    <!-- ================= CONTENT ================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- ================= SEARCH ================= -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#999999"/>

                    <EditText
                        android:id="@+id/etSearchCollection"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="Cari buku..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:textColor="#111111"
                        android:textColorHint="#999999"
                        android:textSize="15sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ================= FILTER ================= -->

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/tabSemua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tab_active"
                        android:paddingStart="22dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="22dp"
                        android:paddingBottom="10dp"
                        android:text="Semua"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabBelum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_tab"
                        android:paddingStart="22dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="22dp"
                        android:paddingBottom="10dp"
                        android:text="Belum"
                        android:textColor="#666666"/>

                    <TextView
                        android:id="@+id/tabSedang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_tab"
                        android:paddingStart="22dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="22dp"
                        android:paddingBottom="10dp"
                        android:text="Sedang"
                        android:textColor="#666666"/>

                    <TextView
                        android:id="@+id/tabSelesai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_tab"
                        android:paddingStart="22dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="22dp"
                        android:paddingBottom="10dp"
                        android:text="Selesai"
                        android:textColor="#666666"/>
                </LinearLayout>

            </HorizontalScrollView>

            <!-- ================= TOTAL ================= -->

            <TextView
                android:id="@+id/tvTotalBook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="18dp"
                android:text="0 Buku"
                android:textColor="#666666"
                android:textSize="14sp"/>

            <!-- ================= RECYCLER ================= -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="14dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_book"/>

        </LinearLayout>


    <!-- ================= BOTTOM NAV ================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- HOME -->

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Beranda"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- FAVORITE -->

        <LinearLayout
            android:id="@+id/navFavorite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Favorit"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- COLLECTION ACTIVE -->

        <LinearLayout
            android:id="@+id/navCollection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#1976D2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koleksi"
                android:textColor="#1976D2"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ADD -->

        <LinearLayout
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#888888"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>